# P·A·R·I·T·Y — Environment Configuration
# Copy to .env and fill in your values.
# .env is gitignored — never commit actual keys.
#
# MINIMUM:      Set GOOGLE_API_KEY — Gemini 2.5 Flash handles everything
# FULL STACK:   Add FEATHERLESS_API_KEY + N8N_WEBHOOK_URL + MIRO_ACCESS_TOKEN

# ══ GOOGLE GEMINI (Primary AI Provider) ════════════════════════
# Model: gemini-2.5-flash (1M token context, best speed/quality)
# Get key: https://aistudio.google.com/app/apikey  ← free tier available
GOOGLE_API_KEY=

# Override model if needed (optional):
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_FAST_MODEL=gemini-2.0-flash

# ══ FEATHERLESS AI (LovHack S2 Sponsor — Fallback) ════════════
# Used when: user provides their own key via UI, OR as server fallback
# Get key: https://featherless.ai/onboarding?returnTo=/account
# 4,300+ open-source models via OpenAI-compatible API
FEATHERLESS_API_KEY=

# Model overrides (optional):
# FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct
# FEATHERLESS_FAST_MODEL=Qwen/Qwen2.5-7B-Instruct

# ══ n8n (LovHack S2 Sponsor — Optional) ══════════════════════
# Enables "AUTOMATE" button on verdict screen
# Local setup: npx n8n → http://localhost:5678 → import n8n-workflow.json
N8N_WEBHOOK_URL=

# ══ MIRO (LovHack S2 Sponsor — Optional) ═════════════════════
# Enables "MIRO MAP" button on verdict screen
# Get token: https://miro.com/app/settings/user-profile/apps → Developer App
MIRO_ACCESS_TOKEN=
MIRO_TEAM_ID=

# ══ SERVER ════════════════════════════════════════════════════
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
