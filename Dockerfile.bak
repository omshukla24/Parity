# P.A.R.I.T.Y. - Google Cloud Run
# Single-stage: Python backend + pre-built React frontend
# Run 'npm run build' locally first, then 'gcloud run deploy parity --source .'

FROM python:3.11-slim

WORKDIR /app

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend source
COPY main.py .
COPY agents/ ./agents/

# Copy pre-built React frontend (built locally before deploy)
COPY dist/ ./dist/

# Cloud Run sets PORT (default 8080)
ENV PORT=8080

EXPOSE 8080

CMD uvicorn main:app --host 0.0.0.0 --port ${PORT}
